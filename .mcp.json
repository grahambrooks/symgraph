{
  "mcpServers": {
    "symgraph": {
      "type": "stdio",
      "command": "cargo",
      "args": ["run", "--", "serve"],
      "env": {
        "SYMGRAPH_ROOT": "."
      },
      "autoApprove": [
        "symgraph-context",
        "symgraph-search",
        "symgraph-callers",
        "symgraph-callees",
        "symgraph-impact",
        "symgraph-definition",
        "symgraph-file",
        "symgraph-references",
        "symgraph-reindex",
        "symgraph-node",
        "symgraph-status",
        "symgraph-hierarchy",
        "symgraph-path",
        "symgraph-unused",
        "symgraph-implementations",
        "symgraph-diff-impact"
      ]
    }
  }
}
